# ============================================================
#  小念（ai-girlfriend）配置模板
#  用法：把本文件复制为 .env，按你自己的环境填写。
#  所有路径都【支持相对路径】，相对的是项目根目录（本文件所在目录），
#  这样整个文件夹拷到别的电脑/别的盘符也能直接跑，不用改绝对路径。
# ============================================================

# ---------- 对话大模型（必填）----------
# 支持 OpenAI 官方，或任意兼容 OpenAI 接口的第三方 / 本地服务（DeepSeek、Ollama、LM Studio…）
# 也可以不填这里，启动后在设置面板(◐)的「API 设置」里随时改、还能“测试连接”。
# ↓ 请填写你的「对话大模型」Key（DeepSeek / 任意兼容 OpenAI 接口的服务商均可）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL=deepseek-chat
# 可在设置面板(◐)里快速切换的模型列表（逗号分隔）
MODELS=deepseek-chat,deepseek-reasoner

GIRLFRIEND_NAME=小念

# 主动关心间隔（分钟）
PROACTIVE_INTERVAL_MIN=15

# ---------- Live2D 形象（可选）----------
LIVE2D_ENABLED=true
# 相对路径（相对项目根）或绝对路径；留空=不显示形象
# 默认用官方免费可商用示例「桃濑日和 - PRO」(hiyori_pro)；本包仅内置此可商用模型
LIVE2D_MODEL=assets/live2d/hiyori_pro/runtime/hiyori_pro_t11.model3.json
# 嘴型参数名：留空自动探测（从模型 model3.json 的 LipSync 组，回退 ParamMouthOpenY）。
# 若你的模型嘴型参数不叫 ParamMouthOpenY（如老模型用 ParamMouthOpen），在此写死覆盖。
LIVE2D_MOUTH_PARAM=
LIVE2D_PORT=9742
GUI_CONTROL_PORT=9744

# ---------- 语音：麦克风输入(ASR) + 字节 Seed-TTS 云端声音输出(TTS)（可选）----------
VOICE_INPUT_ENABLED=true
# local=本地 faster-whisper(离线免费，需先跑 download_model.py 下模型) | openai=OpenAI Whisper API
ASR_BACKEND=local
ASR_MODEL=small
ASR_LANGUAGE=zh
# 麦克风设备：留空=自动优先选名字含「花再」的；也可填设备名子串或索引
ASR_DEVICE=

VOICE_OUTPUT_ENABLED=true
# 扬声器设备：留空=系统默认；也可填数字索引或设备名子串
TTS_OUTPUT_DEVICE=
# 语音播放音量(0~1)
TTS_VOLUME=0.4

# ---------- 语音输出引擎：字节 Seed-TTS（云端 AI 音色，非克隆）----------
# 唯一支持的引擎：seedtts（官方 AI 合成音色、非克隆、无侵权、零本地配置）
TTS_BACKEND=seedtts
# 字节 Seed-TTS（火山引擎「豆包语音合成大模型」v3）：官方 AI 音色，非克隆、无侵权
# 申请：火山引擎控制台 → 语音 → 豆包语音合成大模型 → 创建应用，拿到 APP ID 和 Access Key
SEEDTTS_APP_ID=
SEEDTTS_ACCESS_KEY=
# 角色键：qingleng_yujie 清冷御姐 | xie_yujie 屑御姐 | keai_luoli 可爱萝莉 | zhengtai 正太 | chengnan 成男
SEEDTTS_VOICE=qingleng_yujie
SEEDTTS_SPEED=1.0
# 把「性格情感权重系统」映射到语音声调：开心/生气/伤心… 会让语气、语速、音量随之变化。
# 设为 false 则语音始终中性（若你的火山引擎账号不支持 emotion 参数，可关掉避免报错）。
SEEDTTS_EMOTION_ENABLED=true

# ---------- 屏幕陪伴（可选）----------
SCREEN_WATCH_ENABLED=true
SCREEN_WATCH_INTERVAL_SEC=5
SCREEN_WATCH_SETTLE_SEC=20
SCREEN_WATCH_MIN_GAP_MIN=10
SCREEN_WATCH_MILESTONES=30,60,120
SCREEN_CAPTURE_ENABLED=false

# ---------- 多模态视觉（可选，需单独申请视觉模型 Key）----------
VISION_ENABLED=false
VISION_API_KEY=
VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VISION_MODEL=glm-4v-flash
VISION_MAX_WIDTH=1280

# ---------- 受约束自主权限（白名单内自调参，绝不动系统/代码）----------
AUTONOMY_ENABLED=true
AUTONOMY_CONFIRM_MAJOR=true
AUTONOMY_ANALYZE_MIN=5
COMFORT_BIAS=0.0
ENCOURAGE_MOTION_ENABLED=false
FILE_BACKUP_ENABLED=false
FILE_BACKUP_INTERVAL_MIN=30

# ---------- 小念替你操作电脑文件（创建/写文本文件，如计划、笔记；默认开）----------
FILE_OPS_ENABLED=true

# ---------- 小念的「性格情感权重系统」（情绪随聊天/行为波动，性格缓慢演变）----------
# 情绪维度：开心/生气/伤心/平静/不安。性格由长期情绪累计的【差值】决定，变化很慢。
# 底层逻辑不变：无论情绪/性格如何，小念的最终目的始终是「让玩家生活越来越好」。
EMOTION_ENABLED=true
# true=用 LLM 判断用户话语触发小念的什么情绪（更准，但每次对话多一次 API 调用）；
# false=用内置关键词规则（零额外开销、离线可用，足够自然）
EMOTION_LLM_PERCEIVE=false
# 长期累计速率（越大性格演变越快）；想让性格更稳定就调小（如 0.5）
EMOTION_ACCUM_RATE=1.0
# 每隔多少分钟分析一次性格演变
EMOTION_ANALYZE_MIN=10

# ---------- 输入条样式 ----------
INPUT_BG=#241f33
INPUT_FG=#ffd9e8
INPUT_ALPHA=0.82
INPUT_TOPMOST=true
